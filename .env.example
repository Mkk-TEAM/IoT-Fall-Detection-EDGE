# ── Camera stream (stream_server.py) ─────────────────────────────────────────
EDGE_STREAM_HOST=0.0.0.0
EDGE_STREAM_PORT=8081
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15
JPEG_QUALITY=80

# Public IP/hostname that the browser uses to reach this Pi
EDGE_PUBLIC_HOST=192.168.2.14

# ── Video recording (record_service.py) ──────────────────────────────────────
EDGE_STREAM_URL=http://localhost:8081/stream.mjpg
CLIP_DIR=/media/usb/camera
CLIP_SEGMENT_SECONDS=300
CLIP_RETENTION_HOURS=72

# ── IMU simulator (imu_simulator.py) ─────────────────────────────────────────
BE_BASE_URL=http://localhost:3000/api/v1
EDGE_SECRET=<shared_secret_must_match_BE_EDGE_SECRET>
IMU_DEVICE_ID=imu_001
GATEWAY_ID=gw_001
HEALTH_LOG_INTERVAL_SECONDS=5
FALL_PROBABILITY_PER_MINUTE=0.2
