# ── Camera stream (stream_server.py / edge-streamer C++) ─────────────────────
EDGE_STREAM_HOST=0.0.0.0
EDGE_STREAM_PORT=8081
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15
JPEG_QUALITY=80

# Public IP/hostname that the browser uses to reach this Pi
EDGE_PUBLIC_HOST=192.168.2.14

# ── Video recording (record_service.py) ──────────────────────────────────────
EDGE_STREAM_URL=http://localhost:8081/stream.mjpg
CLIP_DIR=/media/usb/camera
CLIP_SEGMENT_SECONDS=300
CLIP_RETENTION_HOURS=72

# ── Backend connection (shared by BLE client + simulator) ────────────────────
BE_BASE_URL=http://localhost:3000/api/v1
EDGE_SECRET=<shared_secret_must_match_BE_EDGE_SECRET>
IMU_DEVICE_ID=imu_001
GATEWAY_ID=gw_001
HEALTH_LOG_INTERVAL_SECONDS=5

# ── BLE IMU client (edge-imu-ble) ────────────────────────────────────────────
BLE_DEVICE_NAME=FallDetect-IMU
BLE_NOTIFY_CHAR_UUID=12345678-1234-1234-1234-123456789abc
BLE_SCAN_TIMEOUT_MS=10000
BLE_RECONNECT_INIT_MS=1000
BLE_RECONNECT_MAX_MS=10000

# Health HTTP server exposed by edge-imu-ble (port 8082)
IMU_HEALTH_HOST=0.0.0.0
IMU_HEALTH_PORT=8082
IMU_STATS_INTERVAL_SEC=10

# ── Fall detector (edge-imu-ble) ─────────────────────────────────────────────
# Path to JSON config file — edit thresholds without rebuilding.
FALL_DETECTOR_CONFIG=fall_detector_config.json

# ── Python IMU simulator (imu_simulator.py) — dev/debug only ─────────────────
FALL_PROBABILITY_PER_MINUTE=0.2
